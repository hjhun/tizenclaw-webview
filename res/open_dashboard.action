{
  "name": "openDashboard",
  "type": "appControl",
  "category": "utility",
  "description": "An action to open the TizenClaw Dashboard",
  "inputSchema": {
    "type": "object",
    "properties": {
      "url": {
        "type": "string",
        "description": "The URL to open, typically localhost:9090",
        "default": "http://localhost:9090"
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {}
  },
  "requiredPrivileges": [
    "http://tizen.org/privilege/internet"
  ],
  "details": {
    "appid": "org.tizen.tizenclaw-webview"
  }
}
